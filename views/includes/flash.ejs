<% if (success && success.length) { %>
<div id="flash-success" class="alert alert-success alert-dismissible fade show col-6 offset-3" role="alert">
    <%= success %>
</div>
<% } %>

<% if (error && error.length) { %>
<div id="flash-error" class="alert alert-danger alert-dismissible fade show col-6 offset-3" role="alert">
    <%= error %>
</div>
<% } %>



<script>

setTimeout(() => {

const success = document.getElementById("flash-success");
const error = document.getElementById("flash-error");

if(success){
success.style.display = "none";
}

if(error){
error.style.display = "none";
}

},3000); // 3 seconds

</script>