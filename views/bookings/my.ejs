<% layout('layouts/boilerplate') -%>

  <style>
    .bookings-container {
      max-width: 900px;
      margin: auto;
      margin-top: 40px;
    }

    .booking-card {
      display: flex;
      gap: 20px;
      align-items: center;
      padding: 18px;
      border-radius: 14px;
      background: white;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
      margin-bottom: 20px;
    }

    .booking-img {
      width: 120px;
      height: 90px;
      object-fit: cover;
      border-radius: 10px;
    }

    .booking-info {
      flex: 1;
    }

    .status-badge {
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
    }

    .pending {
      background: #fef3c7;
      color: #92400e;
    }

    .accepted {
      background: #dcfce7;
      color: #166534;
    }

    .rejected {
      background: #fee2e2;
      color: #991b1b;
    }
  </style>


  <div class="bookings-container">

    <h3 class="mb-4 fw-bold">
      My Bookings (<%= bookings.length %>)
    </h3>

    <% if(bookings.length===0){ %>

      <p class="text-muted">
        No bookings yet.
      </p>

      <% } %>


        <% bookings.forEach(b=> { %>

          <div class="booking-card">

            <!-- IMAGE -->

            <% if(b.listing && b.listing.image){ %>

              <img src="<%= b.listing.image.url %>" class="booking-img">

              <% } else { %>

                <img src="https://via.placeholder.com/120x90?text=No+Image" class="booking-img">

                <% } %>


                  <!-- DETAILS -->

                  <div class="booking-info">

                    <h5 class="mb-1">
                      <%= b.listing ? b.listing.title : "Listing not available" %>
                    </h5>

                    <p class="text-muted mb-1">
                      Host: <%= b.host ? b.host.username : "Unknown host" %>
                    </p>

                    <span class="status-badge

                        <%= b.status === " accepted" ? "accepted" : b.status==="rejected" ? "rejected" : "pending" %>

                      ">

                      <%= b.status %>

                    </span>

                  </div>

          </div>

          <% }) %>

  </div>