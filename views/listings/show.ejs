<% layout('layouts/boilerplate') -%>

  <style>
    body {
      background: linear-gradient(180deg,
          #f8fafc 0%,
          #f1f5f9 100%);
    }
  </style>

  <div class="container-fluid px-5 mt-4">

    <!-- TITLE -->

    <h2 class="fw-bold">
      <%= listing.title %>
    </h2>

    <p class="text-muted">

      <i class="fa-solid fa-star text-warning"></i>
      <%= listing.avgRating || "New" %>

        <i class="fa-solid fa-location-dot ms-2"></i>
        <%= listing.location %>, <%= listing.country %>

    </p>

    <!-- IMAGE GALLERY -->

    <div class="row g-2 mb-4">

      <div class="col-md-8">

        <img src="<%= listing.image.url %>" class="img-fluid rounded" style="height:460px;width:100%;object-fit:cover;">

      </div>

      <div class="col-md-4 d-flex flex-column gap-2">

        <img src="<%= listing.image.url %>" class="img-fluid rounded" style="height:140px;object-fit:cover;">
        <img src="<%= listing.image.url %>" class="img-fluid rounded" style="height:140px;object-fit:cover;">
        <img src="<%= listing.image.url %>" class="img-fluid rounded" style="height:140px;object-fit:cover;">

      </div>

    </div>


    <div class="row">

      <!-- LEFT SIDE -->

      <div class="col-md-7">

        <h5>Hosted by <b>
            <%= listing.owner.username %>
          </b></h5>

        <p class="mt-3">

          <%= listing.description %>

        </p>

        <h4 class="mt-3">

          ₹ <%= listing.price %>
            <span class="text-muted fs-6"> / night</span>

        </h4>

      </div>


      <!-- RIGHT SIDE BOOKING -->

      <div class="col-md-5">

        <div class="card shadow-sm p-4 rounded-4">

          <h4 class="mb-3">
            ₹ <%= listing.price %> <span class="text-muted fs-6"> / night</span>
          </h4>

          <form id="bookingForm" data-listing-id="<%= listing._id %>">

            <div class="mb-2">
              <label class="form-label">Check-in</label>
              <input type="date" name="checkIn" class="form-control" required>
            </div>

            <div class="mb-2">
              <label class="form-label">Check-out</label>
              <input type="date" name="checkOut" class="form-control" required>
            </div>

            <button class="btn btn-danger w-100 mt-3 py-2" type="submit">
              Book Now
            </button>

            <p class="text-muted text-center mt-2">
              You won't be charged yet
            </p>

          </form>


          <!-- PAYMENT BUTTON (Hidden Initially) -->

          <div id="paymentSection" style="display:none;" class="mt-3">

            <a id="paymentLink" class="btn btn-danger w-100">
              Proceed to Payment
            </a>

          </div>

        </div>

      </div>


      <hr class="mt-4">


      <!-- REVIEWS -->

      <h4 class="fw-bold">Leave a Review</h4>

      <% if(currUser){ %>

        <form action="/listings/<%= listing._id %>/reviews" method="POST" class="card p-3 shadow-sm border-0">

          <label class="form-label">Rating</label>

          <fieldset class="starability-basic">

            <input type="radio" name="review[rating]" value="1">
            <label>1</label>

            <input type="radio" name="review[rating]" value="2">
            <label>2</label>

            <input type="radio" name="review[rating]" value="3">
            <label>3</label>

            <input type="radio" name="review[rating]" value="4">
            <label>4</label>

            <input type="radio" name="review[rating]" value="5">
            <label>5</label>

          </fieldset>

          <label class="mt-2">Comment</label>

          <textarea name="review[comment]" class="form-control" rows="3" required></textarea>

          <button class="btn btn-dark w-100 mt-3">

            Submit

          </button>

        </form>

        <% } %>


          <!-- ALL REVIEWS -->

          <div class="row mt-4">

            <% for(review of listing.reviews){ %>

              <div class="col-md-5">

                <div class="card shadow-sm border-0 p-3 mb-3">

                  <h6>@<%= review.author.username %>
                  </h6>

                  <p class="starability-result" data-rating="<%= review.rating %>"></p>

                  <p>
                    <%= review.comment %>
                  </p>

                </div>

              </div>

              <% } %>

          </div>


          <hr>


          <!-- MAP -->

          <h4 class="fw-bold">Where you'll be</h4>

          <div id="map" style="height:400px;width:100%;border-radius:12px;margin-bottom:30px;"></div>

    </div>

    <script src="/js/script.js"></script>

    <script src="https://maps.googleapis.com/maps/api/js?key=<%=process.env.GOOGLE_MAPS_API_KEY %>&callback=initMap"
      async defer></script>